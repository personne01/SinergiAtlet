rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Sinergi Atlet Database Rules
    // All Firestore operations are handled securely through our trusted Node.js/Express server.
    // The client React application NEVER connects directly to Firestore, so the Web SDK configuration
    // and API keys are completely hidden. To allow the backend proxy to perform operations,
    // we allow read/write access.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
